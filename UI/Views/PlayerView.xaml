<UserControl x:Class="PortablePlayer.UI.Views.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PortablePlayer.UI.Converters"
             Loaded="OnLoaded"
             Background="#101010">
  <UserControl.Resources>
    <converters:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </UserControl.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0"
               Margin="0,0,0,10">
      <StackPanel Orientation="Horizontal"
                  DockPanel.Dock="Right">
        <Button Margin="0,0,8,0"
                Padding="12,6"
                Content="{Binding RefreshText}"
                Command="{Binding RefreshCommand}" />
        <Button Margin="0,0,8,0"
                Padding="12,6"
                Content="{Binding EditText}"
                Command="{Binding EditCommand}" />
        <Button Padding="12,6"
                Content="{Binding BackText}"
                Command="{Binding BackCommand}" />
      </StackPanel>
      <TextBlock Text="{Binding GroupName}"
                 VerticalAlignment="Center"
                 Foreground="White"
                 FontSize="24"
                 FontWeight="SemiBold" />
    </DockPanel>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="{Binding IsNavigationOpen, Converter={StaticResource BoolToGridLengthConverter}}" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0"
              CornerRadius="10"
              Background="#1D1D1D"
              BorderThickness="1"
              BorderBrush="#2F2F2F">
        <ContentControl Content="{Binding CurrentMediaView}" />
      </Border>

      <Border Grid.Column="1"
              Margin="12,0,0,0"
              Padding="8"
              CornerRadius="10"
              Background="#1D1D1D"
              Visibility="{Binding IsNavigationOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <DockPanel>
          <Button DockPanel.Dock="Bottom"
                  Padding="10,6"
                  Margin="0,8,0,0"
                  Content="{Binding JumpText}"
                  Command="{Binding JumpToItemCommand}" />
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding NavigationGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Expander Header="{Binding Header}"
                            IsExpanded="True"
                            Margin="0,0,0,8">
                    <ListBox ItemsSource="{Binding Items}"
                             SelectedItem="{Binding DataContext.SelectedNavigationItem, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                             MouseDoubleClick="OnNavigationDoubleClick"
                             BorderThickness="0"
                             Background="Transparent">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,3"
                                  Padding="6"
                                  CornerRadius="6"
                                  Background="#2A2A2A">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Border Width="64"
                                      Height="40"
                                      Background="#101010"
                                      CornerRadius="4"
                                      BorderBrush="#3A3A3A"
                                      BorderThickness="1">
                                <Image Source="{Binding Thumbnail}"
                                       Stretch="UniformToFill" />
                              </Border>
                              <StackPanel Grid.Column="1"
                                          Margin="8,0,0,0">
                                <TextBlock Text="{Binding FileName}"
                                           Foreground="White"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Foreground"
                                              Value="White" />
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMissing}"
                                                     Value="True">
                                          <Setter Property="Foreground"
                                                  Value="#FFB3B3" />
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Loops}"
                                           Foreground="#BFBFBF"
                                           FontSize="11" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Expander>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2"
            Margin="0,10,0,0"
            Padding="8"
            CornerRadius="10"
            Background="#202020"
            BorderBrush="#2F2F2F"
            BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal"
                    Grid.Column="0"
                    HorizontalAlignment="Left">
          <Button Padding="12,6"
                  Margin="0,0,8,0"
                  Content="{Binding PrevGroupText}"
                  Command="{Binding PreviousGroupCommand}" />
          <Button Padding="12,6"
                  Content="{Binding PrevText}"
                  Command="{Binding PreviousCommand}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Grid.Column="1"
                    HorizontalAlignment="Center">
          <TextBlock Text="{Binding ModeIndicator}"
                     Foreground="#73F8A8"
                     FontSize="22"
                     FontWeight="Bold"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0" />
          <Button Padding="12,6"
                  Content="{Binding ToggleModeText}"
                  Command="{Binding ToggleModeCommand}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Grid.Column="2"
                    HorizontalAlignment="Right">
          <Button Padding="12,6"
                  Margin="0,0,8,0"
                  Content="{Binding NextText}"
                  Command="{Binding NextCommand}" />
          <Button Padding="12,6"
                  Margin="0,0,8,0"
                  Content="{Binding NextGroupText}"
                  Command="{Binding NextGroupCommand}" />
          <Button Padding="12,6"
                  Content="{Binding NavigationText}"
                  Command="{Binding ToggleNavigationCommand}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>

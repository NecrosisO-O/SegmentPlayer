<Window x:Class="PortablePlayer.UI.Views.PlaylistEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="900"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#171717">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="{Binding GroupName}"
               Foreground="White"
               FontSize="24"
               FontWeight="SemiBold" />

    <Border Grid.Row="1"
            Margin="0,12,0,12"
            CornerRadius="10"
            Background="#222222">
      <ListBox x:Name="ItemsList"
               ItemsSource="{Binding Items}"
               SelectedItem="{Binding SelectedItem}"
               AllowDrop="True"
               BorderThickness="0"
               Background="Transparent"
               PreviewMouseLeftButtonDown="OnListPreviewMouseLeftButtonDown"
               MouseMove="OnListMouseMove"
               Drop="OnListDrop">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Margin="8,4"
                    Padding="10"
                    CornerRadius="8"
                    Background="#2B2B2B">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="4*" />
                  <ColumnDefinition Width="2*" />
                  <ColumnDefinition Width="2*" />
                  <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding FileName}"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Margin="8,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding LoopsText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="2"
                         Margin="8,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding GroupText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="3"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="#FFA9A9"
                           Text="{Binding Missing, StringFormat=Missing: {0}}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <DockPanel Grid.Row="2">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#90EE90"
                 VerticalAlignment="Center"
                 DockPanel.Dock="Left" />
      <StackPanel Orientation="Horizontal"
                  DockPanel.Dock="Right"
                  HorizontalAlignment="Right">
        <Button Padding="12,6"
                Margin="0,0,8,0"
                Content="{Binding NormalizeText}"
                Command="{Binding NormalizeGroupsCommand}" />
        <Button Padding="12,6"
                Margin="0,0,8,0"
                Content="{Binding RemoveMissingText}"
                Command="{Binding RemoveMissingCommand}" />
        <Button Padding="12,6"
                Margin="0,0,8,0"
                Content="{Binding CancelText}"
                Command="{Binding CancelCommand}" />
        <Button Padding="12,6"
                Content="{Binding SaveText}"
                Command="{Binding SaveCommand}" />
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>

<UserControl x:Class="PortablePlayer.UI.Views.GroupSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#171717">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="{Binding TitleText}"
               Foreground="White"
               FontSize="30"
               FontWeight="Bold" />

    <Border Grid.Row="1"
            Margin="0,16,0,16"
            CornerRadius="10"
            Background="#222222">
      <Grid>
        <ListBox ItemsSource="{Binding Groups}"
                 SelectedItem="{Binding SelectedGroup}"
                 Margin="12"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,4"
                      Padding="12"
                      CornerRadius="8"
                      Background="#2C2C2C">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Name}"
                             Foreground="White"
                             FontSize="18"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding MediaType}"
                             Foreground="#B4F0C8"
                             FontSize="13"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Margin="0,6,0,0"
                             Text="{Binding Status}"
                             TextWrapping="Wrap"
                             Foreground="#CECECE"
                             FontSize="13">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground"
                                Value="#CECECE" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsValid}"
                                       Value="False">
                            <Setter Property="Foreground"
                                    Value="#FFB3B3" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <DockPanel Grid.Row="2">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#D5D5D5"
                 VerticalAlignment="Center"
                 DockPanel.Dock="Left" />
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  DockPanel.Dock="Right">
        <Button Margin="0,0,8,0"
                Padding="14,7"
                Command="{Binding ReloadCommand}"
                Content="{Binding RefreshText}" />
        <Button Margin="0,0,8,0"
                Padding="14,7"
                Command="{Binding EditSelectedCommand}"
                Content="{Binding EditText}" />
        <Button Margin="0,0,8,0"
                Padding="14,7"
                Command="{Binding OpenSettingsCommand}"
                Content="{Binding SettingsText}" />
        <Button Padding="14,7"
                Command="{Binding PlaySelectedCommand}"
                Content="{Binding PlayText}" />
      </StackPanel>
    </DockPanel>
  </Grid>
</UserControl>

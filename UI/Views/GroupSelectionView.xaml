<UserControl x:Class="PortablePlayer.UI.Views.GroupSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#171717">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Text="{Binding TitleText}"
                 Foreground="White"
                 FontSize="30"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button Margin="0,0,8,0"
                Padding="14,7"
                Command="{Binding ReloadCommand}"
                Content="{Binding RefreshText}" />
        <Button Padding="14,7"
                Command="{Binding OpenSettingsCommand}"
                Content="{Binding SettingsText}" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="1"
            Margin="0,16,0,16"
            CornerRadius="10"
            Background="#222222">
      <ListBox x:Name="GroupList"
               ItemsSource="{Binding Groups}"
               SelectedItem="{Binding SelectedGroup}"
               Margin="12"
               Background="Transparent"
               BorderThickness="0"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               MouseDoubleClick="OnGroupListDoubleClick">
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="Margin"
                    Value="0,3" />
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="10"
                    CornerRadius="8"
                    Background="#2B2B2B">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="BorderBrush"
                          Value="#3A3A3A" />
                  <Setter Property="BorderThickness"
                          Value="1" />
                  <Setter Property="Opacity"
                          Value="1" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsValid}"
                                 Value="False">
                      <Setter Property="Opacity"
                              Value="0.68" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                 Value="True">
                      <Setter Property="BorderBrush"
                              Value="#6AA8FF" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="132" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="120"
                        Height="68"
                        CornerRadius="6"
                        Background="#1F1F1F"
                        BorderBrush="#383838"
                        BorderThickness="1"
                        ClipToBounds="True">
                  <Grid>
                    <Image Source="{Binding PreviewImage}"
                           Stretch="UniformToFill" />
                    <TextBlock Text="{Binding NoPreviewText}"
                               Foreground="#AAAAAA"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility"
                                  Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasPreview}"
                                         Value="True">
                              <Setter Property="Visibility"
                                      Value="Collapsed" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}"
                             Foreground="White"
                             FontSize="18"
                             FontWeight="SemiBold" />
                  <StackPanel Orientation="Horizontal"
                              Margin="0,4,0,0">
                    <TextBlock Text="{Binding MediaTypeText}"
                               FontSize="12"
                               FontWeight="SemiBold">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground"
                                  Value="#B4F0C8" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUnknownType}"
                                         Value="True">
                              <Setter Property="Foreground"
                                      Value="#FF8F8F" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="12,0,0,0"
                               Text="{Binding ItemCountText}"
                               Foreground="#CECECE"
                               FontSize="12" />
                  </StackPanel>
                  <TextBlock Margin="0,4,0,0"
                             Text="{Binding Status}"
                             TextWrapping="Wrap"
                             Foreground="#CECECE"
                             FontSize="12">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground"
                                Value="#CECECE" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsValid}"
                                       Value="False">
                            <Setter Property="Foreground"
                                    Value="#FFB3B3" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                  <Button Margin="0,0,8,0"
                          Padding="12,6"
                          Click="OnEditRowClick"
                          Content="{Binding DataContext.EditText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                  <Button Padding="12,6"
                          Click="OnPlayRowClick"
                          IsEnabled="{Binding IsValid}"
                          Content="{Binding DataContext.PlayText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <TextBlock Grid.Row="2"
               Text="{Binding StatusText}"
               Foreground="#D5D5D5"
               VerticalAlignment="Center" />
  </Grid>
</UserControl>

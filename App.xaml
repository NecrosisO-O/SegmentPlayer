<Application x:Class="PortablePlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:PortablePlayer.UI.ViewModels"
             xmlns:views="clr-namespace:PortablePlayer.UI.Views">
  <Application.Resources>
    <DataTemplate DataType="{x:Type viewModels:SplashViewModel}">
      <views:SplashView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:GroupSelectionViewModel}">
      <views:GroupSelectionView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:PlayerViewModel}">
      <views:PlayerView />
    </DataTemplate>
  </Application.Resources>
</Application>
